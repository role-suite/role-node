{
  "name": "role-node",
  "version": "1.0.0",
  "description": "role server written in node",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --exec tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "create:module": "node scripts/create-module.mjs",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:migrate:up": "tsx scripts/migrate.ts up",
    "db:migrate:down": "tsx scripts/migrate.ts down",
    "db:migrate:status": "tsx scripts/migrate.ts status",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:run": "vitest --run",
    "test:coverage": "vitest --run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/role-suite/role-node.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "bugs": {
    "url": "https://github.com/role-suite/role-node/issues"
  },
  "homepage": "https://github.com/role-suite/role-node#readme",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mysql2": "^3.15.1",
    "pg": "^8.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.15.5",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
